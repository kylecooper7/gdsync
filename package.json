{
  "name": "@gdsync/gdsync",
  "version": "1.1.3",
  "type": "module",
  "description": "Sync Google Docs to a local content file for AI agent editing",
  "main": "dist/cli.js",
  "bin": {
    "gdsync": "dist/cli.js"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "skill.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "google-docs",
    "sync",
    "ai-agent",
    "cli",
    "markdown",
    "google-drive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylecooper7/gdsync"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "googleapis": "^140.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
